{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "preinstall": "node -e \"const fs=require('fs');['package-lock.json','yarn.lock'].forEach(f=>{try{fs.rmSync(f)}catch{}});const ua=process.env.npm_config_user_agent||'';if(!ua.startsWith('pnpm')){console.error('Use pnpm instead');process.exit(1)}\"",
    "dev": "next dev",
    "start": "next start",
    "seed": "pnpm --filter @workspace/scripts run seed",
    "db:seed-admin": "pnpm --filter @workspace/scripts run seed-admin",
    "db:seed-artist-info": "pnpm --filter @workspace/scripts run seed-artist-info",
    "db:seed-books": "pnpm --filter @workspace/scripts run seed-book-offerings",
    "db:seed-portal-test-user": "pnpm --filter @workspace/scripts run seed-portal-test-user",
    "push": "pnpm --filter @workspace/db run push",
    "codegen": "pnpm --filter @workspace/api-spec run codegen",
    "build": "pnpm run typecheck && next build",
    "typecheck:libs": "tsc --build tsconfig.libs.json",
    "typecheck:app": "tsc --noEmit -p tsconfig.json",
    "typecheck": "pnpm run typecheck:libs && pnpm run typecheck:app && pnpm -r --filter \"./scripts\" --if-present run typecheck"
  },
